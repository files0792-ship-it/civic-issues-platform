# Browser calls API via same origin in dev (Vite proxy). For production builds,
# set this to your deployed API URL (include protocol, no trailing slash).
VITE_API_URL=

# Firebase client config (from Firebase Console → Project settings → Your apps → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
